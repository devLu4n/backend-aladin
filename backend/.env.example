# URL de conexão do PostgreSQL usada pelo Prisma
DATABASE_URL=

# Porta em que a API vai rodar
PORT=

# Ambiente da aplicação
NODE_ENV=

# Segredo usado para assinar o cookie de sessão (troque por um valor aleatório e seguro)
SESSION_SECRET=

# Origem do front-end permitida pelo CORS (o Vite roda em 5173 por padrão)
CORS_ORIGIN=
